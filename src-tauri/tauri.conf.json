{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PKU Course Desktop",
  "version": "0.2.0",
  "identifier": "ink.arthals.pku-course-desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PKU Course Desktop",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "contentProtected": false,
        "skipTaskbar": false,
        "create": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' https: http:",
        "img-src": "'self' https: http: data: blob:",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "frame-src": "'self' https: http:"
      },
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": false
    },
    "withGlobalTauri": false,
    "enableGTKAppId": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "appimage", "dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "inject-scripts/**/*"
    ],
    "copyright": "Copyright (c) 2024 Arthals",
    "category": "Education",
    "shortDescription": "PKU course video downloader",
    "longDescription": "A desktop application for downloading PKU course videos with batch download support",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {}
}
